# ==========================================
# CONSTELACIÓN VIVA - Environment Configuration
# ==========================================
# Copy this file to .env and update values for your deployment
# IMPORTANT: Never commit actual secrets to version control
# Use GitHub Secrets for CI/CD and secure vaults for production

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_USER=cv_user
DB_PASSWORD=changeme_secure_password_here
DB_NAME=constelacion_viva
# Format: postgresql+asyncpg://user:password@host:port/dbname
# Used by backend to connect to PostgreSQL

# ==========================================
# BACKEND CONFIGURATION
# ==========================================
ENVIRONMENT=development
# Options: development, staging, production

SECRET_KEY=your-secret-key-change-in-production
# JWT secret for signing tokens (min 32 characters for production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"

API_HOST=0.0.0.0
API_PORT=8000
# Host and port for FastAPI server

FRONTEND_URL=http://localhost:3000
# URL where frontend is accessible (for CORS)

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
FRONTEND_API_URL=http://localhost:8000
# API endpoint accessible from frontend browser
# In production, use your backend domain (with protocol)

# ==========================================
# AWS S3 CONFIGURATION (Media Storage)
# ==========================================
S3_BUCKET=constelacion-viva-media
S3_REGION=us-east-1
S3_ACCESS_KEY=your_aws_access_key
S3_SECRET_KEY=your_aws_secret_key
S3_ENDPOINT=https://s3.amazonaws.com
# S3_ENDPOINT for S3-compatible services (e.g., MinIO): http://minio:9000

# ==========================================
# MERCADO PAGO CONFIGURATION (Payments)
# ==========================================
MERCADO_PAGO_ACCESS_TOKEN=your_mercado_pago_access_token
# Get from: https://www.mercadopago.com.ar/developers/panel

# ==========================================
# RESEND CONFIGURATION (Email Service)
# ==========================================
RESEND_API_KEY=your_resend_api_key
# Get from: https://resend.com/api-keys
# Used for sending password reset and notification emails

# ==========================================
# DOCKER COMPOSE OVERRIDES (optional)
# ==========================================
# DOCKERFILE_BACKEND=Dockerfile.dev
# DOCKERFILE_FRONTEND=Dockerfile.dev
# Uncomment to use development Dockerfiles (with hot reload)

# ==========================================
# NODE CONFIGURATION (Frontend)
# ==========================================
NODE_ENV=development
# Options: development, production

# ==========================================
# LOGGING & MONITORING
# ==========================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ==========================================
# DEPLOYMENT & CORS
# ==========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Comma-separated list of origins allowed for CORS in production

# LocalStack S3 (dev sandbox)
S3_BUCKET=constelacion-dev
S3_REGION=us-east-1
S3_ACCESS_KEY=localstack
S3_SECRET_KEY=localstack
S3_ENDPOINT=http://localstack:4566
S3_PUBLIC_ENDPOINT=http://localhost:4566
